{% extends 'admin/layout.html.twig' %}

{% block title %}Examiner demande #{{ request.id }} - Coursia Admin{% endblock %}
{% block page_title %}Examiner la demande Chevalier #{{ request.id }}{% endblock %}

{% block content %}
<div class="row">
    <!-- Colonne gauche: Informations personnelles -->
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-person"></i> Informations personnelles
                <span class="badge bg-{{ request.requestType == 'national' ? 'primary' : 'info' }} float-end">
                    {{ request.requestType|upper }}
                </span>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 80px; height: 80px; font-size: 2rem;">
                        {{ request.firstName|slice(0,1)|upper }}{{ request.lastName|slice(0,1)|upper }}
                    </div>
                    <h5 class="mt-2">{{ request.firstName }} {{ request.lastName }}</h5>
                </div>

                <table class="table table-sm">
                    <tr>
                        <td><i class="bi bi-envelope text-muted"></i></td>
                        <td>{{ request.email }}</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-phone text-muted"></i></td>
                        <td>{{ request.phone }}</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-flag text-muted"></i></td>
                        <td>{{ request.nationality ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-geo-alt text-muted"></i></td>
                        <td>{{ request.residenceAddress ?? request.city ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-calendar text-muted"></i></td>
                        <td>{{ request.createdAt|date('d/m/Y H:i') }}</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Contact d'urgence -->
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-telephone-fill"></i> Contact d'urgence
            </div>
            <div class="card-body">
                {% if request.emergencyContactPhone %}
                    <p class="mb-0"><i class="bi bi-phone"></i> {{ request.emergencyContactPhone }}</p>
                {% else %}
                    <p class="text-muted mb-0">Non renseigné</p>
                {% endif %}
            </div>
        </div>

        {% if request.message %}
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-chat-quote"></i> Message du demandeur
            </div>
            <div class="card-body">
                <p class="mb-0 fst-italic">"{{ request.message }}"</p>
            </div>
        </div>
        {% endif %}
    </div>

    <!-- Colonne centrale: Documents -->
    <div class="col-md-4">
        {% if request.requestType == 'national' %}
        <!-- National: CIP + Véhicule -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <i class="bi bi-card-heading"></i> Identité (CIP)
            </div>
            <div class="card-body">
                <p><strong>N° CIP :</strong>
                    <span class="badge bg-primary fs-6">{{ request.idCardNumber ?? 'Non renseigné' }}</span>
                </p>
                {% if request.cipPath %}
                    <a href="/{{ request.cipPath }}" target="_blank" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-file-earmark-pdf"></i> Voir le CIP (PDF)
                    </a>
                {% else %}
                    <div class="alert alert-warning py-2 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> CIP non fourni
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-bicycle"></i> Véhicule
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <tr>
                        <td><strong>Type</strong></td>
                        <td>{{ request.vehicleType ? request.vehicleType|upper : '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Immatriculation</strong></td>
                        <td><span class="badge bg-dark">{{ request.vehicleRegistration ?? '-' }}</span></td>
                    </tr>
                </table>
                {% if request.carteGrisePath %}
                    <a href="/{{ request.carteGrisePath }}" target="_blank" class="btn btn-outline-success btn-sm w-100">
                        <i class="bi bi-file-earmark-pdf"></i> Voir la carte grise (PDF)
                    </a>
                {% else %}
                    <div class="alert alert-warning py-2 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Carte grise non fournie
                    </div>
                {% endif %}
            </div>
        </div>

        {% else %}
        <!-- International: Passeport + Visa + Billet -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <i class="bi bi-passport"></i> Documents de voyage
            </div>
            <div class="card-body">
                <p><strong>N° Passeport :</strong>
                    <span class="badge bg-primary fs-6">{{ request.passportNumber ?? 'Non renseigné' }}</span>
                </p>
                {% if request.passportPath %}
                    <a href="/{{ request.passportPath }}" target="_blank" class="btn btn-outline-primary btn-sm w-100 mb-2">
                        <i class="bi bi-file-earmark-pdf"></i> Voir le passeport (PDF)
                    </a>
                {% else %}
                    <div class="alert alert-danger py-2 mb-2">
                        <i class="bi bi-x-circle"></i> Passeport non fourni
                    </div>
                {% endif %}

                {% if request.visaPath %}
                    <a href="/{{ request.visaPath }}" target="_blank" class="btn btn-outline-secondary btn-sm w-100 mb-2">
                        <i class="bi bi-file-earmark-pdf"></i> Voir le visa (PDF)
                    </a>
                {% else %}
                    <div class="alert alert-warning py-2 mb-2">
                        <i class="bi bi-exclamation-triangle"></i> Visa non fourni
                    </div>
                {% endif %}

                {% if request.billetAvionPath %}
                    <a href="/{{ request.billetAvionPath }}" target="_blank" class="btn btn-outline-info btn-sm w-100">
                        <i class="bi bi-file-earmark-pdf"></i> Voir le billet d'avion (PDF)
                    </a>
                {% else %}
                    <div class="alert alert-warning py-2 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Billet d'avion non fourni
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-globe"></i> Destination
            </div>
            <div class="card-body">
                <p><strong>Pays :</strong> {{ request.destinationCountry ?? '-' }}</p>
                <p class="mb-0"><strong>Logement :</strong> {{ request.destinationAddress ?? '-' }}</p>
            </div>
        </div>
        {% endif %}
    </div>

    <!-- Colonne droite: Décision -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-light">
                <i class="bi bi-check-circle"></i> Décision
            </div>
            <div class="card-body">
                <form action="{{ path('admin_chevaliers_approve', {id: request.id}) }}" method="POST" class="mb-3">
                    <button type="submit" class="btn btn-success btn-lg w-100" onclick="return confirm('Approuver cette demande ?')">
                        <i class="bi bi-check-lg"></i> Approuver
                    </button>
                </form>

                <hr>

                <form action="{{ path('admin_chevaliers_reject', {id: request.id}) }}" method="POST">
                    <div class="mb-2">
                        <textarea name="reason" class="form-control" rows="2" placeholder="Raison du refus"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Refuser cette demande ?')">
                        <i class="bi bi-x-lg"></i> Refuser
                    </button>
                </form>

                <hr>

                <a href="{{ path('admin_chevaliers_pending') }}" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left"></i> Retour à la liste
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
