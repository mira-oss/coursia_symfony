<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Coursia Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background: #F3F4F6;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .login-card {
            display: flex;
            width: 1020px;
            max-width: 100%;
            min-height: 480px;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 24px 80px rgba(0,0,0,0.14), 0 4px 20px rgba(0,0,0,0.08);
        }

        /* ── Panneau gauche ── */
        .login-left {
            flex: 0 0 44%;
            background: linear-gradient(160deg, #422057 0%, #5c2e7a 50%, #3a1a4e 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            padding: 52px 48px;
            overflow: hidden;
        }

        .deco-circle {
            position: absolute;
            border-radius: 50%;
        }
        .deco-circle.c1 { width: 320px; height: 320px; bottom: -100px; right: -100px; background: rgba(255,214,98,0.08); }
        .deco-circle.c2 { width: 180px; height: 180px; bottom: 80px;   right: 80px;   background: rgba(255,214,98,0.06); }
        .deco-circle.c3 { width: 100px; height: 100px; top: 50px;      right: 40px;   background: rgba(255,214,98,0.10); }
        .deco-circle.c4 { width: 60px;  height: 60px;  top: 160px;     left: -20px;   background: rgba(255,214,98,0.07); }

        .deco-dots {
            position: absolute;
            bottom: 140px;
            left: 36px;
            display: grid;
            grid-template-columns: repeat(4, 8px);
            gap: 10px;
        }
        .deco-dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,214,98,0.25); display: block; }

        .login-left-body {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .left-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 48px;
        }
        .left-logo-icon {
            width: 40px; height: 40px;
            background: #FFD662;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
        }
        .left-logo-icon i { font-size: 20px; color: #422057; }
        .left-logo-text { font-size: 20px; font-weight: 800; color: #FFD662; letter-spacing: -0.3px; }

        .left-tag {
            font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
            text-transform: uppercase; color: rgba(255,214,98,0.65); margin-bottom: 16px;
        }
        .left-title {
            font-size: 38px; font-weight: 800; color: #fff;
            line-height: 1.12; letter-spacing: -0.5px; margin-bottom: 18px;
        }
        .left-title span { color: #FFD662; }
        .left-desc { font-size: 14px; color: rgba(255,255,255,0.60); line-height: 1.75; max-width: 280px; }

        .left-stats { margin-top: auto; display: flex; gap: 12px; }
        .stat-badge {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,214,98,0.18);
            border-radius: 14px; padding: 12px 16px; flex: 1;
        }
        .stat-badge .num { font-size: 22px; font-weight: 800; color: #FFD662; line-height: 1; }
        .stat-badge .lbl { font-size: 11px; color: rgba(255,255,255,0.50); margin-top: 4px; }

        /* ── Panneau droit ── */
        .login-right {
            flex: 1;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 32px 52px;
            overflow: hidden;
        }

        /* Titre centré */
        .form-title {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
            text-align: center;
            margin-bottom: 4px;
            margin-top: -24px;
        }

        /* Alertes */
        .alert {
            border-radius: 12px; border: none;
            font-size: 13px; padding: 12px 14px; margin-bottom: 20px;
        }
        .alert-danger  { background: #FEE2E2; color: #991B1B; }
        .alert-success { background: #D1FAE5; color: #065F46; }

        /* Champs */
        .field-group { margin-bottom: 11px; }
        .field-label { font-size: 13px; font-weight: 600; color: #374151; display: block; margin-bottom: 7px; }
        .field-wrap { position: relative; }

        .field-icon {
            position: absolute; left: 14px; top: 50%;
            transform: translateY(-50%); color: #9CA3AF; font-size: 16px; pointer-events: none;
        }

        .field-input {
            width: 100%;
            border: 2px solid #D1D5DB;
            border-radius: 12px;
            padding: 13px 46px;
            font-size: 14px;
            color: #111827;
            background: #fff;
            transition: all 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }
        .field-input:focus {
            outline: none;
            border-color: #422057;
            box-shadow: 0 0 0 3px rgba(66,32,87,0.10);
        }
        .field-input::placeholder { color: #A0AEC0; }

        /* Bouton œil */
        .eye-btn {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%);
            background: none; border: none;
            color: #9CA3AF; font-size: 18px;
            cursor: pointer; padding: 0; line-height: 1;
            transition: color 0.2s;
        }
        .eye-btn:hover { color: #422057; }

        .row-opts {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 16px; margin-top: 2px;
        }
        .remember-wrap {
            display: flex; align-items: center; gap: 8px;
            font-size: 13px; color: #6B7280; cursor: pointer;
        }
        .remember-wrap input[type="checkbox"] { width: 16px; height: 16px; accent-color: #422057; cursor: pointer; }

        .forgot-link { font-size: 13px; font-weight: 600; color: #422057; text-decoration: none; }
        .forgot-link:hover { color: #331746; text-decoration: underline; }

        /* Bouton se connecter */
        .btn-signin {
            width: 100%; padding: 14px;
            background: #422057; color: #FFD662;
            border: none; border-radius: 12px;
            font-size: 15px; font-weight: 700;
            cursor: pointer; transition: all 0.25s;
            margin-bottom: 14px; letter-spacing: 0.3px;
        }
        .btn-signin:hover {
            background: #331746;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(66,32,87,0.30);
        }

        /* Séparateur */
        .divider {
            display: flex; align-items: center;
            gap: 12px; margin-bottom: 12px;
            color: #6B7280; font-size: 13px; font-weight: 500;
        }
        .divider span { white-space: nowrap; }
        .divider::before, .divider::after {
            content: ''; flex: 1; height: 1px; background: #D1D5DB;
        }

        /* Boutons sociaux */
        .social-row { display: flex; gap: 12px; justify-content: center; }
        .social-btn {
            width: 46px; height: 46px;
            display: flex; align-items: center; justify-content: center;
            border: 1.5px solid #E5E7EB; border-radius: 12px;
            background: #fff; cursor: pointer; text-decoration: none;
            transition: all 0.2s;
        }
        .social-btn:hover {
            border-color: #422057; background: #f8f0ff;
            color: #422057; transform: translateY(-1px);
        }
        .social-btn i { font-size: 18px; }
        .si-google   { color: #EA4335; }
        .si-facebook { color: #1877F2; }
        .si-apple    { color: #000; }

        /* Lien s'inscrire */
        .no-account { text-align: center; margin-top: 12px; font-size: 13px; color: #9CA3AF; }
        .no-account a { color: #422057; font-weight: 700; text-decoration: none; }
        .no-account a:hover { text-decoration: underline; }

        @media (max-width: 760px) {
            .login-card { flex-direction: column; }
            .login-left { flex: none; min-height: 200px; padding: 32px 28px; }
            .left-stats { display: none; }
            .login-right { padding: 36px 28px; }
            .social-row { flex-direction: column; }
        }
    </style>
</head>
<body>

<div class="login-card">

    <!-- ── Gauche ── -->
    <div class="login-left">
        <div class="deco-circle c1"></div>
        <div class="deco-circle c2"></div>
        <div class="deco-circle c3"></div>
        <div class="deco-circle c4"></div>
        <div class="deco-dots">
            {% for i in 1..12 %}<span></span>{% endfor %}
        </div>

        <div class="login-left-body">
        </div>
    </div>

    <!-- ── Droite ── -->
    <div class="login-right">

        <!-- Titre centré -->
        <h2 class="form-title">Connexion</h2>
        <p style="font-size:13px; color:#9CA3AF; text-align:center; margin-top:6px; margin-bottom:0;">Entrez vos identifiants pour accéder à votre compte.</p>

        {% if error %}
            <div class="alert alert-danger mt-4"><i class="bi bi-exclamation-circle me-2"></i>{{ error }}</div>
        {% endif %}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success mt-4"><i class="bi bi-check-circle me-2"></i>{{ message }}</div>
        {% endfor %}

        <form method="POST" action="{{ path('admin_login') }}" style="margin-top: 16px;">

            <div class="field-group">
                <label class="field-label">Email</label>
                <div class="field-wrap">
                    <i class="bi bi-person field-icon"></i>
                    <input type="email" name="email" class="field-input"
                           placeholder="identifiant@gmail.com"
                           required value="{{ last_email ?? '' }}">
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">Mot de passe</label>
                <div class="field-wrap">
                    <i class="bi bi-lock field-icon"></i>
                    <input type="password" name="password" id="pwdInput"
                           class="field-input" placeholder="Votre mot de passe" required>
                    <button type="button" class="eye-btn" id="eyeBtn" onclick="togglePwd()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <div class="row-opts">
                <label class="remember-wrap">
                    <input type="checkbox" name="remember"> Se souvenir de moi
                </label>
                <a href="{{ path('admin_forgot_password') }}" class="forgot-link">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="btn-signin">
                Se connecter
            </button>

            <!-- Boutons sociaux EN BAS du bouton se connecter -->
            <div class="divider"><span>ou se connecter avec</span></div>

            <div class="social-row">
                <a href="#" class="social-btn" onclick="return false;" title="Google">
                    <i class="bi bi-google si-google"></i>
                </a>
                <a href="#" class="social-btn" onclick="return false;" title="Facebook">
                    <i class="bi bi-facebook si-facebook"></i>
                </a>
                <a href="#" class="social-btn" onclick="return false;" title="Apple">
                    <i class="bi bi-apple si-apple"></i>
                </a>
            </div>

            <p class="no-account">
                Pas encore de compte ? <a href="{{ path('admin_register') }}">S'inscrire</a>
            </p>

        </form>
    </div>
</div>

<script>
    function togglePwd() {
        const input = document.getElementById('pwdInput');
        const icon  = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>
</body>
</html>
