<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Coursia Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --coursia-orange: #F97316;
            --coursia-orange-hover: #EA580C;
            --coursia-dark: #020617;
            --coursia-gray: #E5E7EB;
            --coursia-gray-light: #F9FAFB;
        }

        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #F5F5F5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .login-container {
            background: white;
            border-radius: 30px;
            box-shadow: 0 20px 80px rgba(0, 0, 0, 0.15),
                        0 8px 30px rgba(0, 0, 0, 0.1),
                        0 0 0 1px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            display: flex;
            width: 75%;
            max-width: 1200px;
            height: 75vh;
            min-height: 500px;
        }

        .login-illustration {
            flex: 0 0 50%;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, #F97316 0%, #FB923C 60%, #FDBA74 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
            padding: 40px;
        }

        .login-illustration::before {
            content: '';
            position: absolute;
            top: -60px; left: -40px;
            width: 220px; height: 220px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .login-illustration::after {
            content: '';
            position: absolute;
            bottom: -50px; right: -30px;
            width: 180px; height: 180px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .login-illustration img {
            width: 80%;
            max-width: 320px;
            object-fit: contain;
            position: relative;
            z-index: 1;
            filter: drop-shadow(0 16px 32px rgba(0,0,0,0.2));
        }

        .login-illustration .brand {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .login-illustration .brand h2 {
            font-size: 32px;
            font-weight: 800;
            color: white;
            margin: 0 0 6px 0;
            letter-spacing: -0.5px;
        }

        .login-illustration .brand p {
            font-size: 14px;
            color: rgba(255,255,255,0.85);
            margin: 0;
        }

        .login-form-section {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: linear-gradient(160deg, #DBEAFE 0%, #BFDBFE 100%);
        }

        .login-title {
            font-size: 28px;
            font-weight: 700;
            color: var(--coursia-dark);
            margin-bottom: 8px;
            text-align: center;
        }

        .login-subtitle {
            color: #6B7280;
            font-size: 14px;
            margin-bottom: 35px;
            text-align: center;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--coursia-dark);
            margin-bottom: 8px;
            display: block;
        }

        .form-control {
            border: 1.5px solid var(--coursia-gray);
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 14px;
            transition: border-color 0.3s, box-shadow 0.3s;
            background: white;
            width: 100%;
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px rgba(249,115,22,0.15);
            border-color: var(--coursia-orange);
            background: white;
            outline: none;
        }

        .form-control::placeholder {
            color: #9CA3AF;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper .form-control {
            padding-right: 44px;
        }

        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9CA3AF;
            padding: 0;
            font-size: 16px;
            line-height: 1;
        }

        .toggle-password:hover {
            color: var(--coursia-orange);
        }

        .btn-coursia {
            background: var(--coursia-orange);
            border: none;
            border-radius: 50px;
            padding: 14px 35px;
            font-weight: 600;
            color: white;
            transition: all 0.3s;
            width: 100%;
        }

        .btn-coursia:hover {
            background: var(--coursia-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(249, 115, 22, 0.3);
        }

        .btn-coursia i {
            margin-left: 8px;
        }

        .alert {
            border-radius: 12px;
            border: none;
            font-size: 14px;
        }

        .alert-danger {
            background: #FEE2E2;
            color: #991B1B;
        }

        .alert-success {
            background: #D1FAE5;
            color: #065F46;
        }

        .no-account {
            text-align: center;
            margin-top: 25px;
            color: #6B7280;
            font-size: 14px;
        }

        .no-account a {
            color: var(--coursia-orange);
            font-weight: 600;
            text-decoration: none;
            border-bottom: 2px solid var(--coursia-orange);
            padding-bottom: 2px;
            transition: all 0.3s;
        }

        .no-account a:hover {
            color: var(--coursia-orange-hover);
            border-bottom-color: var(--coursia-orange-hover);
        }

        @media (max-width: 768px) {
            .login-container {
                width: 95%;
                height: auto;
                min-height: auto;
            }
            .login-illustration {
                display: none;
            }
            .login-form-section {
                padding: 40px 30px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <!-- Illustration Section -->
        <div class="login-illustration">
            <div class="brand">
                <h2>Coursia</h2>
                <p>Plateforme de gestion des livraisons</p>
            </div>
            <img src="{{ asset('images/image2-removebg-preview.png') }}" alt="Coursia">
        </div>

        <!-- Form Section -->
        <div class="login-form-section">
            <h1 class="login-title">Connexion</h1>
            <p class="login-subtitle">Entrez vos identifiants pour accéder à votre compte.</p>

            {% if error %}
                <div class="alert alert-danger mb-4">
                    <i class="bi bi-exclamation-circle me-2"></i>{{ error }}
                </div>
            {% endif %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success mb-4">
                    <i class="bi bi-check-circle me-2"></i>{{ message }}
                </div>
            {% endfor %}

            <form method="POST" action="{{ path('admin_login') }}">
                <div class="mb-4">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="identifiant@gmail.com"
                           pattern="[a-zA-Z0-9._%+\-]+@gmail\.com$"
                           title="L'adresse email doit être au format identifiant@gmail.com"
                           required value="{{ last_email ?? '' }}">
                </div>

                <div class="mb-2">
                    <label class="form-label">Mot de passe</label>
                    <div class="input-wrapper">
                        <input type="password" name="password" id="passwordInput" class="form-control" placeholder="Votre mot de passe" required>
                        <button type="button" class="toggle-password" onclick="togglePassword()">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <div class="text-end mb-4">
                    <a href="{{ path('admin_forgot_password') }}" style="font-size:13px; color:#6B7280; text-decoration:none;">Mot de passe oublié ?</a>
                </div>

                <button type="submit" class="btn btn-coursia">
                    Se connecter <i class="bi bi-arrow-right"></i>
                </button>

                <p class="no-account">
                    Pas encore de compte ? <a href="{{ path('admin_register') }}">Créer</a>
                </p>
            </form>

            <script>
                function togglePassword() {
                    const input = document.getElementById('passwordInput');
                    const icon = document.getElementById('eyeIcon');
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.className = 'bi bi-eye-slash';
                    } else {
                        input.type = 'password';
                        icon.className = 'bi bi-eye';
                    }
                }
            </script>
        </div>
    </div>
</body>
</html>
