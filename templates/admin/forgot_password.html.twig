<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mot de passe oublié - Coursia Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background: #F3F4F6;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card-wrap {
            display: flex;
            width: 1020px;
            max-width: 100%;
            min-height: 480px;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 24px 80px rgba(0,0,0,0.14), 0 4px 20px rgba(0,0,0,0.08);
        }

        /* ── Panneau gauche ── */
        .card-left {
            flex: 0 0 44%;
            background: linear-gradient(160deg, #422057 0%, #5c2e7a 50%, #3a1a4e 100%);
            position: relative;
            overflow: hidden;
        }

        .deco-circle { position: absolute; border-radius: 50%; }
        .deco-circle.c1 { width: 320px; height: 320px; bottom: -100px; right: -100px; background: rgba(255,214,98,0.08); }
        .deco-circle.c2 { width: 180px; height: 180px; bottom: 80px;   right: 80px;   background: rgba(255,214,98,0.06); }
        .deco-circle.c3 { width: 100px; height: 100px; top: 50px;      right: 40px;   background: rgba(255,214,98,0.10); }
        .deco-circle.c4 { width: 60px;  height: 60px;  top: 160px;     left: -20px;   background: rgba(255,214,98,0.07); }

        .deco-dots {
            position: absolute; bottom: 140px; left: 36px;
            display: grid; grid-template-columns: repeat(4, 8px); gap: 10px;
        }
        .deco-dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,214,98,0.25); display: block; }

        /* ── Panneau droit ── */
        .card-right {
            flex: 1;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 56px;
            overflow: hidden;
        }

        /* Icône centrale */
        .lock-icon {
            width: 64px; height: 64px;
            background: rgba(66,32,87,0.10);
            border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px auto;
        }
        .lock-icon i { font-size: 28px; color: #422057; }

        .form-title {
            font-size: 26px;
            font-weight: 800;
            color: #111827;
            text-align: center;
            margin-bottom: 6px;
        }

        .form-subtitle {
            font-size: 13px;
            color: #9CA3AF;
            text-align: center;
            margin-bottom: 28px;
            line-height: 1.6;
        }

        .field-group { margin-bottom: 14px; }
        .field-label { font-size: 13px; font-weight: 600; color: #374151; display: block; margin-bottom: 7px; }
        .field-wrap { position: relative; }

        .field-icon {
            position: absolute; left: 14px; top: 50%;
            transform: translateY(-50%); color: #9CA3AF;
            font-size: 16px; pointer-events: none;
        }

        .field-input {
            width: 100%;
            border: 2px solid #D1D5DB;
            border-radius: 12px;
            padding: 13px 14px 13px 44px;
            font-size: 14px;
            color: #111827;
            background: #fff;
            transition: all 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }
        .field-input:focus {
            outline: none;
            border-color: #422057;
            box-shadow: 0 0 0 3px rgba(66,32,87,0.10);
        }
        .field-input::placeholder { color: #A0AEC0; }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #422057;
            color: #FFD662;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s;
            margin-top: 8px;
            margin-bottom: 16px;
            letter-spacing: 0.3px;
        }
        .btn-submit:hover {
            background: #331746;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(66,32,87,0.30);
        }

        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #9CA3AF;
            text-decoration: none;
            transition: color 0.2s;
        }
        .back-link:hover { color: #422057; }

        .alert {
            border-radius: 12px; border: none;
            font-size: 13px; padding: 12px 14px; margin-bottom: 16px;
        }
        .alert-danger  { background: #FEE2E2; color: #991B1B; }
        .alert-success { background: #D1FAE5; color: #065F46; }

        @media (max-width: 760px) {
            .card-wrap { flex-direction: column; }
            .card-left { flex: none; min-height: 140px; }
            .card-right { padding: 36px 28px; }
        }
    </style>
</head>
<body>

<div class="card-wrap">

    <!-- ── Gauche ── -->
    <div class="card-left">
        <div class="deco-circle c1"></div>
        <div class="deco-circle c2"></div>
        <div class="deco-circle c3"></div>
        <div class="deco-circle c4"></div>
        <div class="deco-dots">
            {% for i in 1..12 %}<span></span>{% endfor %}
        </div>
    </div>

    <!-- ── Droite ── -->
    <div class="card-right">

        <div class="lock-icon">
            <i class="bi bi-lock-fill"></i>
        </div>

        <h2 class="form-title">Mot de passe oublié</h2>
        <p class="form-subtitle">Entrez votre adresse email pour recevoir<br>un code de vérification.</p>

        {% if error %}
            <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i>{{ error }}</div>
        {% endif %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>{{ message }}</div>
        {% endfor %}

        <form method="POST" action="{{ path('admin_forgot_password') }}">
            <div class="field-group">
                <label class="field-label">Email</label>
                <div class="field-wrap">
                    <i class="bi bi-envelope field-icon"></i>
                    <input type="email" name="email" class="field-input"
                           placeholder="identifiant@gmail.com" required>
                </div>
            </div>

            <button type="submit" class="btn-submit">
                Envoyer le code <i class="bi bi-send ms-1"></i>
            </button>

            <a href="{{ path('admin_login') }}" class="back-link">
                <i class="bi bi-arrow-left"></i> Retour à la connexion
            </a>
        </form>
    </div>
</div>

</body>
</html>
