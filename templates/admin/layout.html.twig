<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Coursia Admin{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* Theme Variables - Light Mode */
        :root, [data-theme="light"] {
            --coursia-orange: #422057;
            --coursia-orange-hover: #331746;
            --coursia-orange-light: #f5f0f9;
            --coursia-yellow: #FFD662;
            --coursia-green: #16A34A;
            --coursia-green-hover: #15803D;
            --coursia-green-light: #DCFCE7;
            --coursia-dark: #1F2937;
            --coursia-gray: #E5E7EB;
            --coursia-gray-light: #f5f0f9;
            --coursia-bg: #f0eaf7;
            --coursia-white: #FFFFFF;
            --coursia-text: #374151;
            --coursia-text-muted: #9CA3AF;
            --sidebar-width: 260px;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        /* Sidebar plus sombre en dark mode */
        [data-theme="dark"] .sidebar {
            background: linear-gradient(180deg, #1e0a2e 0%, #150720 100%);
        }

        /* Dark Mode */
        [data-theme="dark"] {
            --coursia-orange: #FFD662;
            --coursia-orange-hover: #ffe88a;
            --coursia-orange-light: rgba(255, 214, 98, 0.12);
            --coursia-dark: #F9FAFB;
            --coursia-gray: #374151;
            --coursia-gray-light: #2d1f3d;
            --coursia-bg: #1a0f24;
            --coursia-white: #241535;
            --coursia-text: #E5E7EB;
            --coursia-text-muted: #9CA3AF;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        }

        /* Dark mode specific overrides */
        [data-theme="dark"] .card {
            background: #1F2937 !important;
            border: 1px solid #374151 !important;
        }

        [data-theme="dark"] .card-header {
            background: #1F2937 !important;
            border-bottom: 1px solid #374151 !important;
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .card-body {
            background: #1F2937 !important;
        }

        [data-theme="dark"] .table {
            color: #E5E7EB !important;
            background: transparent !important;
        }

        [data-theme="dark"] .table thead th {
            color: #9CA3AF !important;
            background: transparent !important;
            border-color: #374151 !important;
        }

        [data-theme="dark"] .table tbody tr {
            background: transparent !important;
        }

        [data-theme="dark"] .table tbody tr:hover {
            background: #374151 !important;
        }

        [data-theme="dark"] .table td {
            color: #E5E7EB !important;
            border-color: #374151 !important;
            background: transparent !important;
        }

        [data-theme="dark"] .table td small {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .stat-card {
            background: #1F2937 !important;
            border: 1px solid #374151 !important;
        }

        [data-theme="dark"] .stat-info h3 {
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .stat-info p {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .section-title {
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .filter-btn,
        [data-theme="dark"] .form-select,
        [data-theme="dark"] .form-control {
            background: #1F2937 !important;
            border-color: #374151 !important;
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .form-select option {
            background: #1F2937 !important;
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .search-box input {
            background: #1F2937 !important;
            color: #E5E7EB !important;
            border: 1px solid #374151 !important;
        }

        [data-theme="dark"] .search-box input::placeholder {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .notif-dropdown,
        [data-theme="dark"] .profile-dropdown {
            background: #1F2937 !important;
            border-color: #374151 !important;
        }

        [data-theme="dark"] .notif-header,
        [data-theme="dark"] .profile-dropdown-header {
            border-color: #374151 !important;
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .notif-header h6,
        [data-theme="dark"] .profile-dropdown-header .name {
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .profile-dropdown-header .email {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .notif-item:hover,
        [data-theme="dark"] .profile-dropdown-item:hover {
            background: #374151 !important;
        }

        [data-theme="dark"] .notif-content p {
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .profile-dropdown-item {
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .amount-cell {
            color: var(--coursia-yellow) !important;
        }

        [data-theme="dark"] .donut-center h2 {
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .donut-center small {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .legend-text {
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .legend-value {
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .promo-card {
            background: linear-gradient(135deg, #422057 0%, #5c2e7a 100%) !important;
        }

        [data-theme="dark"] .text-muted {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .card-body p,
        [data-theme="dark"] .card-body h6,
        [data-theme="dark"] .card-body h5,
        [data-theme="dark"] .card-body h4,
        [data-theme="dark"] .card-body strong,
        [data-theme="dark"] .card-body small,
        [data-theme="dark"] .card-body li,
        [data-theme="dark"] .card-body label,
        [data-theme="dark"] .card-body span:not(.badge) {
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .card-body .text-muted,
        [data-theme="dark"] .card-body h6.text-muted,
        [data-theme="dark"] .card-body small.text-muted {
            color: #9CA3AF !important;
        }

        [data-theme="dark"] .btn-outline-primary {
            border-color: #FFD662 !important;
            color: #FFD662 !important;
        }

        [data-theme="dark"] .btn-outline-primary:hover {
            background: #FFD662 !important;
            color: #422057 !important;
        }

        [data-theme="dark"] .dropdown-menu {
            background: #1F2937 !important;
            border-color: #374151 !important;
        }

        [data-theme="dark"] .dropdown-item {
            color: #E5E7EB !important;
        }

        [data-theme="dark"] .dropdown-item:hover,
        [data-theme="dark"] .dropdown-item:focus {
            background: #374151 !important;
            color: #F9FAFB !important;
        }

        [data-theme="dark"] .dropdown-item.active {
            background: #FFD662 !important;
            color: #422057 !important;
        }

        [data-theme="dark"] .dropdown-divider {
            border-color: #374151 !important;
        }

        * {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--coursia-bg);
            background-image:
                radial-gradient(ellipse at top right, rgba(92,46,122,0.08) 0%, transparent 60%),
                radial-gradient(ellipse at bottom left, rgba(255,214,98,0.06) 0%, transparent 55%);
            min-height: 100vh;
            margin: 0;
            color: var(--coursia-text);
            font-size: 14px;
            line-height: 1.6;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, #422057 0%, #3a1a4e 100%);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            padding: 25px 20px;
            border-right: none;
            transition: background-color 0.3s;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            margin-bottom: 35px;
            padding: 0 10px;
        }

        .sidebar-brand i {
            font-size: 28px;
            color: #FFD662;
        }

        .sidebar-brand span {
            font-size: 24px;
            font-weight: 800;
            color: #FFD662;
            letter-spacing: -0.5px;
        }

        .sidebar-nav {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            min-height: 0;
            scrollbar-width: thin;
            scrollbar-color: var(--coursia-gray) transparent;
        }

        .sidebar-nav::-webkit-scrollbar {
            width: 3px;
        }

        .sidebar-nav::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar-nav::-webkit-scrollbar-thumb {
            background: var(--coursia-gray);
            border-radius: 10px;
        }

        .nav-section {
            margin-bottom: 28px;
        }

        .nav-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255, 214, 98, 0.50);
            padding: 0 16px;
            margin-bottom: 12px;
        }

        .nav-section .nav {
            padding: 0 10px;
        }

        .nav-item {
            margin-bottom: 4px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 10px;
            color: rgba(255, 255, 255, 0.70);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .nav-link:hover {
            background: rgba(255, 214, 98, 0.12);
            color: #FFD662;
        }

        .nav-link.active {
            background: rgba(255, 214, 98, 0.15);
            color: #FFD662;
            font-weight: 600;
        }

        .nav-link i {
            font-size: 20px;
            width: 24px;
        }

        .nav-badge {
            margin-left: auto;
            background: #EF4444;
            color: white;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 50px;
        }

        /* Theme Toggle in Sidebar */
        .theme-toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 14px;
            border-radius: 12px;
            color: rgba(255,255,255,0.70);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .theme-toggle:hover {
            background: rgba(255,214,98,0.12);
            color: #FFD662;
        }

        .theme-toggle-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .theme-toggle-left i {
            font-size: 20px;
            width: 24px;
        }

        .toggle-switch {
            width: 44px;
            height: 24px;
            background: var(--coursia-gray);
            border-radius: 50px;
            position: relative;
            transition: background 0.3s;
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            background: white;
            border-radius: 50%;
            transition: transform 0.3s;
        }

        [data-theme="dark"] .toggle-switch {
            background: #FFD662;
        }

        [data-theme="dark"] .toggle-switch::after {
            transform: translateX(20px);
        }

        /* Promo Card */
        .promo-card {
            background: rgba(255, 214, 98, 0.12);
            border: 1px solid rgba(255, 214, 98, 0.25);
            border-radius: 16px;
            padding: 22px;
            color: white;
            margin-top: auto;
        }

        .promo-card h4 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .promo-card p {
            font-size: 13px;
            opacity: 0.9;
            margin-bottom: 16px;
            line-height: 1.5;
        }

        .promo-btn {
            background: #FFD662;
            color: #422057;
            border: none;
            border-radius: 10px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s;
        }

        .promo-btn:hover {
            background: #ffe88a;
            color: #422057;
            transform: translateY(-1px);
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            background: var(--coursia-bg);
            transition: background-color 0.3s;
        }

        .top-header {
            background: var(--coursia-white);
            padding: 10px 20px 10px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--coursia-gray);
            transition: background-color 0.3s, border-color 0.3s;
            gap: 14px;
        }

        .greeting {
            font-size: 20px;
            font-weight: 700;
            color: var(--coursia-dark);
            letter-spacing: -0.5px;
            white-space: nowrap;
        }

        .header-welcome {
            flex: 1;
        }

        .header-welcome .welcome-day {
            font-size: 12px;
            color: var(--coursia-text-muted);
            font-weight: 500;
            margin-bottom: 2px;
        }

        .header-welcome .welcome-name {
            font-size: 20px;
            font-weight: 800;
            color: var(--coursia-dark);
            letter-spacing: -0.4px;
            line-height: 1.2;
        }

        .header-welcome .welcome-sub {
            font-size: 13px;
            color: var(--coursia-text-muted);
            margin-top: 2px;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .search-box {
            position: relative;
        }

        .search-box input {
            background: var(--coursia-gray-light);
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 12px 20px 12px 48px;
            font-size: 14px;
            width: 300px;
            color: var(--coursia-text);
            transition: all 0.2s;
        }

        .search-box input::placeholder {
            color: var(--coursia-text-muted);
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--coursia-orange);
            background: var(--coursia-white);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
        }

        .search-box i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--coursia-text-muted);
            font-size: 18px;
        }

        /* Dropdown Containers */
        .dropdown-container {
            position: relative;
        }

        .header-btn {
            width: 46px;
            height: 46px;
            border: none;
            border-radius: 12px;
            background: var(--coursia-gray-light);
            color: var(--coursia-text);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            font-size: 20px;
        }

        .header-btn:hover {
            background: var(--coursia-orange-light);
            color: var(--coursia-orange);
        }

        .header-btn .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: #EF4444;
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 7px;
            border-radius: 50px;
            min-width: 20px;
            text-align: center;
        }

        /* Notifications Dropdown */
        .notif-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 360px;
            background: var(--coursia-white);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--coursia-gray);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s;
            z-index: 1000;
        }

        .notif-dropdown.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .notif-header {
            padding: 18px 20px;
            border-bottom: 1px solid var(--coursia-gray);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .notif-header h6 {
            font-size: 15px;
            font-weight: 700;
            margin: 0;
            color: var(--coursia-dark);
        }

        .notif-header a {
            font-size: 13px;
            color: var(--coursia-orange);
            text-decoration: none;
            font-weight: 500;
        }

        .notif-list {
            max-height: 320px;
            overflow-y: auto;
        }

        .notif-item {
            display: flex;
            gap: 14px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--coursia-gray-light);
            transition: background 0.2s;
            text-decoration: none;
            color: inherit;
        }

        .notif-item:hover {
            background: var(--coursia-gray-light);
        }

        .notif-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .notif-icon.orange {
            background: var(--coursia-orange-light);
            color: var(--coursia-orange);
        }

        .notif-icon.green {
            background: var(--coursia-green-light);
            color: var(--coursia-green);
        }

        .notif-content {
            flex: 1;
        }

        .notif-content p {
            margin: 0 0 4px 0;
            font-size: 13px;
            color: var(--coursia-text);
            line-height: 1.4;
        }

        .notif-content small {
            color: var(--coursia-text-muted);
            font-size: 12px;
        }

        .notif-empty {
            padding: 40px 20px;
            text-align: center;
            color: var(--coursia-text-muted);
        }

        .notif-empty i {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

        /* Profile Dropdown */
        .profile-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 6px 14px 6px 6px;
            background: var(--coursia-gray-light);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }

        .profile-btn:hover {
            background: var(--coursia-orange-light);
        }

        .admin-avatar {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #422057 0%, #5c2e7a 100%);
            color: #FFD662;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 15px;
        }

        .profile-info {
            text-align: left;
        }

        .profile-info .name {
            font-size: 14px;
            font-weight: 600;
            color: var(--coursia-dark);
            line-height: 1.2;
        }

        .profile-info .role {
            font-size: 12px;
            color: var(--coursia-text-muted);
        }

        .profile-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 280px;
            background: var(--coursia-white);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--coursia-gray);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s;
            z-index: 1000;
        }

        .profile-dropdown.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .profile-dropdown-header {
            padding: 20px;
            border-bottom: 1px solid var(--coursia-gray);
            text-align: center;
        }

        .profile-dropdown-header .avatar-lg {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #422057 0%, #5c2e7a 100%);
            color: #FFD662;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 22px;
            margin: 0 auto 12px;
        }

        .profile-dropdown-header .name {
            font-size: 16px;
            font-weight: 700;
            color: var(--coursia-dark);
            margin-bottom: 2px;
        }

        .profile-dropdown-header .email {
            font-size: 13px;
            color: var(--coursia-text-muted);
        }

        .profile-dropdown-menu {
            padding: 10px;
        }

        .profile-dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 10px;
            color: var(--coursia-text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .profile-dropdown-item:hover {
            background: var(--coursia-gray-light);
            color: var(--coursia-text);
        }

        .profile-dropdown-item i {
            font-size: 18px;
            width: 24px;
            color: var(--coursia-text-muted);
        }

        .profile-dropdown-item.logout {
            color: #DC2626;
        }

        .profile-dropdown-item.logout i {
            color: #DC2626;
        }

        .profile-dropdown-item.logout:hover {
            background: #FEE2E2;
        }

        /* Page Content */
        .page-content {
            padding: 28px 35px;
        }

        /* Filter Bar */
        .filter-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .filter-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .filter-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--coursia-white);
            border: 1px solid var(--coursia-gray);
            border-radius: 10px;
            padding: 10px 16px;
            font-size: 14px;
            font-weight: 500;
            color: var(--coursia-text);
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-btn:hover {
            border-color: var(--coursia-orange);
            color: var(--coursia-orange);
        }

        .filter-btn.active {
            border-color: var(--coursia-orange);
            background: var(--coursia-orange-light);
            color: var(--coursia-orange);
        }

        .filter-btn i {
            font-size: 16px;
        }

        .export-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #422057;
            border: none;
            border-radius: 10px;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 600;
            color: #FFD662;
            cursor: pointer;
            transition: all 0.2s;
        }

        .export-btn:hover {
            background: #331746;
            transform: translateY(-1px);
        }

        /* Stat Cards */
        .stat-card-link {
            display: block;
            text-decoration: none;
            color: inherit;
            height: 100%;
            transition: transform 0.2s ease;
        }

        .stat-card-link:hover {
            transform: translateY(-2px);
        }

        .stat-card-link:hover .stat-card {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        }

        .stat-card {
            background: var(--coursia-white);
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: background-color 0.3s, box-shadow 0.3s;
            height: 100%;
            min-height: 76px;
            border: 1px solid var(--coursia-gray);
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.05);
        }

        .stat-card:hover {
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        }

        .stat-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .stat-icon.orange {
            background: var(--coursia-orange-light);
            color: var(--coursia-orange);
        }

        .stat-icon.green {
            background: var(--coursia-green-light);
            color: var(--coursia-green);
        }

        .stat-icon.blue {
            background: #DBEAFE;
            color: #2563EB;
        }

        .stat-info p {
            color: var(--coursia-text-muted);
            font-size: 12px;
            margin: 0 0 2px 0;
        }

        .stat-info h3 {
            font-size: 17px;
            font-weight: 800;
            color: var(--coursia-dark);
            margin: 0;
            letter-spacing: -0.2px;
        }

        .stat-trend {
            font-size: 11px;
            font-weight: 600;
            margin-top: 3px;
        }

        .stat-trend.up {
            color: #059669;
        }

        .stat-trend.down {
            color: #DC2626;
        }

        /* Section Header */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }

        .section-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--coursia-dark);
            margin: 0;
        }

        .section-link {
            color: var(--coursia-orange);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
        }

        .section-link:hover {
            text-decoration: underline;
        }

        /* Cards */
        .card {
            border: 1px solid var(--coursia-gray);
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            background: var(--coursia-white);
            transition: background-color 0.3s, border-color 0.3s;
        }

        .card-header {
            border-bottom: 1px solid var(--coursia-gray) !important;
            padding: 16px 24px;
            font-weight: 600;
            font-size: 15px;
            background: var(--coursia-white) !important;
        }

        .card-body {
            padding: 24px;
        }

        /* Tables */
        .table {
            margin-bottom: 0;
        }

        .table th {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--coursia-text-muted);
            border-bottom: 2px solid var(--coursia-gray) !important;
            padding: 14px 16px;
            background: var(--coursia-gray-light);
        }

        .table td {
            padding: 16px;
            vertical-align: middle;
            border-bottom: 1px solid var(--coursia-gray) !important;
            font-size: 14px;
            color: var(--coursia-text);
        }

        .table tbody tr:last-child td {
            border-bottom: none !important;
        }

        .table tbody tr:hover {
            background: var(--coursia-gray-light);
        }

        /* Status Badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
        }

        .status-badge i {
            font-size: 14px;
        }

        .status-badge.completed {
            color: #059669;
        }

        .status-badge.pending {
            color: #D97706;
        }

        .status-badge.failed {
            color: #DC2626;
        }

        /* Badge Pills */
        .badge {
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 12px;
        }

        .badge-pending {
            background: #FEF3C7;
            color: #D97706;
        }

        .badge-approved, .badge-active, .badge-success {
            background: var(--coursia-green-light);
            color: var(--coursia-green);
        }

        .badge-rejected, .badge-inactive, .badge-danger {
            background: #FEE2E2;
            color: #DC2626;
        }

        /* Alerts */
        .alert {
            border: none;
            border-radius: 12px;
            font-weight: 500;
        }

        .alert-success {
            background: #D1FAE5;
            color: #065F46;
        }

        .alert-danger {
            background: #FEE2E2;
            color: #991B1B;
        }

        /* Buttons */
        .btn-coursia {
            background: #422057;
            border: none;
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
            color: #FFD662;
            transition: all 0.2s;
        }

        .btn-coursia:hover {
            background: #331746;
            color: #FFD662;
            transform: translateY(-1px);
        }

        /* Form Controls */
        .form-control, .form-select {
            border: 1px solid var(--coursia-gray);
            border-radius: 10px;
            padding: 10px 15px;
            transition: all 0.2s;
            background: var(--coursia-white);
            color: var(--coursia-text);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--coursia-orange);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
        }

        /* Hamburger Menu Button */
        .menu-toggle {
            display: none;
            width: 42px;
            height: 42px;
            border: none;
            border-radius: 10px;
            background: var(--coursia-gray-light);
            color: var(--coursia-text);
            font-size: 22px;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .menu-toggle:hover {
            background: var(--coursia-orange-light);
            color: var(--coursia-orange);
        }

        /* Sidebar Overlay */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .sidebar-overlay.show {
            opacity: 1;
        }

        /* Responsive - Tablette */
        @media (max-width: 992px) {
            .menu-toggle {
                display: flex;
            }

            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
                z-index: 1001;
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar-overlay {
                display: block;
                pointer-events: none;
            }

            .sidebar-overlay.show {
                pointer-events: auto;
            }

            .main-content {
                margin-left: 0;
            }

            .top-header {
                padding: 14px 20px;
            }

            .greeting {
                font-size: 18px;
            }

            .search-box input {
                width: 220px;
            }

            .page-content {
                padding: 20px;
            }

            .profile-info {
                display: none;
            }

            .profile-btn {
                padding: 6px;
                border-radius: 50%;
            }

            .profile-btn .bi-chevron-down {
                display: none;
            }
        }

        /* Responsive - Mobile */
        @media (max-width: 576px) {
            .top-header {
                padding: 12px 16px;
                flex-wrap: wrap;
                gap: 12px;
            }

            .greeting {
                font-size: 16px;
                order: 1;
                flex: 1;
            }

            .header-right {
                order: 2;
                gap: 10px;
            }

            .search-box {
                order: 3;
                width: 100%;
            }

            .search-box input {
                width: 100%;
            }

            .page-content {
                padding: 16px;
            }

            .stat-card {
                padding: 16px;
                gap: 14px;
            }

            .stat-icon {
                width: 46px;
                height: 46px;
                font-size: 20px;
                border-radius: 12px;
            }

            .stat-info h3 {
                font-size: 22px;
            }

            .stat-info p {
                font-size: 12px;
            }

            .section-title {
                font-size: 15px;
            }

            .card-body {
                padding: 16px;
            }

            .table {
                font-size: 13px;
            }

            .table th, .table td {
                padding: 10px 12px;
            }

            .header-btn {
                width: 40px;
                height: 40px;
                font-size: 18px;
            }

            .admin-avatar {
                width: 34px;
                height: 34px;
                font-size: 14px;
            }

            .notif-dropdown {
                width: 300px;
                right: -60px;
            }

            .profile-dropdown {
                width: 250px;
                right: -10px;
            }

            .filter-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .filter-left {
                flex-wrap: wrap;
            }

            .btn-coursia {
                width: 100%;
                text-align: center;
            }
        }
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="{{ path('admin_dashboard') }}" class="sidebar-brand">
            <i class="bi bi-box-seam"></i>
            <span>Coursia</span>
        </a>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-section-title">Principal</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a href="{{ path('admin_dashboard') }}" class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
                            <i class="bi bi-grid-1x2"></i>
                            Vue d'ensemble
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_courses') }}" class="nav-link {% if 'admin_courses' in app.request.attributes.get('_route') %}active{% endif %}">
                            <i class="bi bi-truck"></i>
                            Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_conversations') }}" class="nav-link {% if 'admin_conversations' in app.request.attributes.get('_route') %}active{% endif %}">
                            <i class="bi bi-chat-dots"></i>
                            Messages
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_statistics') }}" class="nav-link {% if app.request.attributes.get('_route') == 'admin_statistics' %}active{% endif %}">
                            <i class="bi bi-bar-chart"></i>
                            Statistiques
                        </a>
                    </li>
                </ul>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Gestion</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a href="{{ path('admin_chevaliers_pending') }}" class="nav-link {% if 'admin_chevaliers' in app.request.attributes.get('_route') %}active{% endif %}">
                            <i class="bi bi-shield-check"></i>
                            Demandes Chevalier
                            {% if pending_chevaliers_count is defined and pending_chevaliers_count > 0 %}
                                <span class="nav-badge">{{ pending_chevaliers_count }}</span>
                            {% endif %}
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_users') }}" class="nav-link">
                            <i class="bi bi-people"></i>
                            Utilisateurs
                        </a>
                    </li>
                </ul>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Preferences</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <div class="theme-toggle" onclick="toggleTheme()">
                            <div class="theme-toggle-left">
                                <i class="bi bi-moon"></i>
                                Mode sombre
                            </div>
                            <div class="toggle-switch"></div>
                        </div>
                    </li>
                </ul>
            </div>

        </nav>
    </aside>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- Main Content -->
    <main class="main-content">
        <header class="top-header">
            <button class="menu-toggle" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            {% block header_left %}
            <h1 class="greeting">{% block page_title %}Dashboard{% endblock %}</h1>
            {% endblock %}

            <div class="header-right">
                <form action="{{ path('admin_search') }}" method="GET" class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" name="q" placeholder="Rechercher un utilisateur, une course..." value="{{ app.request.query.get('q', '') }}">
                </form>

                <!-- Notifications -->
                <div class="dropdown-container">
                    <button class="header-btn" onclick="toggleNotifications()">
                        <i class="bi bi-bell"></i>
                        {% if pending_chevaliers_count is defined and pending_chevaliers_count > 0 %}
                            <span class="notif-badge">{{ pending_chevaliers_count }}</span>
                        {% endif %}
                    </button>
                    <div class="notif-dropdown" id="notifDropdown">
                        <div class="notif-header">
                            <h6>Notifications</h6>
                            <a href="#">Tout marquer lu</a>
                        </div>
                        <div class="notif-list">
                            {% if pending_chevaliers_count is defined and pending_chevaliers_count > 0 %}
                                <a href="{{ path('admin_chevaliers_pending') }}" class="notif-item">
                                    <div class="notif-icon orange">
                                        <i class="bi bi-shield-check"></i>
                                    </div>
                                    <div class="notif-content">
                                        <p><strong>{{ pending_chevaliers_count }}</strong> demande(s) de chevalier en attente</p>
                                        <small>Cliquez pour voir les demandes</small>
                                    </div>
                                </a>
                            {% else %}
                                <div class="notif-empty">
                                    <i class="bi bi-bell-slash"></i>
                                    <p>Aucune notification</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Profile -->
                <div class="dropdown-container">
                    <button class="profile-btn" onclick="toggleProfile()">
                        <div class="admin-avatar">
                            {% if admin is defined and admin %}
                                {{ admin.firstName|slice(0,1)|upper }}
                            {% else %}
                                A
                            {% endif %}
                        </div>
                        <div class="profile-info">
                            <div class="name">{% if admin is defined and admin %}{{ admin.firstName }}{% else %}Admin{% endif %}</div>
                            <div class="role">Administrateur</div>
                        </div>
                        <i class="bi bi-chevron-down" style="color: var(--coursia-text-muted); font-size: 14px;"></i>
                    </button>
                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="profile-dropdown-header">
                            <div class="avatar-lg">
                                {% if admin is defined and admin %}
                                    {{ admin.firstName|slice(0,1)|upper }}
                                {% else %}
                                    A
                                {% endif %}
                            </div>
                            <div class="name">{% if admin is defined and admin %}{{ admin.firstName }} {{ admin.lastName }}{% else %}Administrateur{% endif %}</div>
                            <div class="email">{% if admin is defined and admin %}{{ admin.email }}{% else %}admin@coursia.com{% endif %}</div>
                        </div>
                        <div class="profile-dropdown-menu">
                            <a href="{{ path('admin_profile') }}" class="profile-dropdown-item">
                                <i class="bi bi-person"></i>
                                Mon profil
                            </a>
                            <a href="{{ path('admin_profile') }}#settings" class="profile-dropdown-item">
                                <i class="bi bi-gear"></i>
                                Parametres
                            </a>
                            <a href="{{ path('admin_logout') }}" class="profile-dropdown-item logout">
                                <i class="bi bi-box-arrow-left"></i>
                                Deconnexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} mb-4">
                        <i class="bi bi-{% if label == 'success' %}check-circle{% else %}exclamation-circle{% endif %} me-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Theme Toggle
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
        }

        // Load saved theme
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);

        // Notifications Dropdown
        function toggleNotifications() {
            const dropdown = document.getElementById('notifDropdown');
            const profileDropdown = document.getElementById('profileDropdown');
            profileDropdown.classList.remove('show');
            dropdown.classList.toggle('show');
        }

        // Profile Dropdown
        function toggleProfile() {
            const dropdown = document.getElementById('profileDropdown');
            const notifDropdown = document.getElementById('notifDropdown');
            notifDropdown.classList.remove('show');
            dropdown.classList.toggle('show');
        }

        // Sidebar Toggle (mobile)
        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('show');
            document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
        }

        function closeSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.remove('open');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
        }

        // Fermer la sidebar quand on clique sur un lien (mobile)
        document.querySelectorAll('.sidebar .nav-link').forEach(link => {
            link.addEventListener('click', closeSidebar);
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            const notifDropdown = document.getElementById('notifDropdown');
            const profileDropdown = document.getElementById('profileDropdown');

            if (!e.target.closest('.dropdown-container')) {
                notifDropdown.classList.remove('show');
                profileDropdown.classList.remove('show');
            }
        });
    </script>
    {% block extra_js %}{% endblock %}
</body>
</html>
