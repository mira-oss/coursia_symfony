{% extends 'admin/layout.html.twig' %}

{% block title %}{{ user.firstName }} {{ user.lastName }} - Coursia Admin{% endblock %}
{% block page_title %}Detail utilisateur{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="bg-{{ user.role == 'admin' ? 'danger' : (user.role == 'chevalier' ? 'success' : 'primary') }} text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px; font-size: 2.5rem;">
                    {{ user.firstName|slice(0,1)|upper }}
                </div>
                <h4>{{ user.firstName }} {{ user.lastName }}</h4>
                <p class="text-muted">{{ user.email }}</p>

                {% if user.role == 'admin' %}
                    <span class="badge bg-danger">Admin</span>
                {% elseif user.role == 'chevalier' %}
                    <span class="badge bg-success">Chevalier</span>
                    {% if user.isVerified %}
                        <span class="badge bg-success">Verifie</span>
                    {% else %}
                        <span class="badge bg-warning">Non verifie</span>
                    {% endif %}
                {% else %}
                    <span class="badge bg-primary">Elu</span>
                {% endif %}

                <hr>

                <div class="text-start">
                    <p><strong>Telephone:</strong> {{ user.phone ?? 'Non renseigne' }}</p>
                    <p><strong>Date de naissance:</strong> {{ user.birthDate ?? 'Non renseigne' }}</p>
                    <p><strong>Nationalite:</strong> {{ user.nationality ?? 'Non renseigne' }}</p>
                    <p><strong>Inscrit le:</strong> {{ user.createdAt|date('d/m/Y H:i') }}</p>
                    <p><strong>Statut:</strong>
                        {% if user.isActive %}
                            <span class="text-success">Actif</span>
                        {% else %}
                            <span class="text-danger">Inactif</span>
                        {% endif %}
                    </p>
                </div>

                <hr>

                <div class="d-grid gap-2">
                    {% if user.isActive %}
                        <a href="{{ path('admin_users_toggle', {id: user.id}) }}" class="btn btn-warning" onclick="return confirm('Desactiver cet utilisateur ?')">
                            <i class="bi bi-pause-circle"></i> Desactiver
                        </a>
                    {% else %}
                        <a href="{{ path('admin_users_toggle', {id: user.id}) }}" class="btn btn-success">
                            <i class="bi bi-play-circle"></i> Activer
                        </a>
                    {% endif %}
                    {% if user.role != 'admin' %}
                        <form method="POST" action="{{ path('admin_users_delete', {id: user.id}) }}"
                              onsubmit="return confirm('Supprimer définitivement {{ user.firstName }} {{ user.lastName }} ? Cette action est irréversible.')">
                            <button type="submit" class="btn btn-danger w-100">
                                <i class="bi bi-trash"></i> Supprimer l'utilisateur
                            </button>
                        </form>
                    {% endif %}
                    <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Courses de l'utilisateur -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-truck"></i> Courses ({{ courses|length }})
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Status</th>
                            <th>Role</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for course in courses %}
                        <tr>
                            <td>#{{ course.id }}</td>
                            <td>{{ course.title|slice(0,25) }}...</td>
                            <td>
                                {% if course.status == 'finished' %}
                                    <span class="badge bg-success">Termine</span>
                                {% elseif course.status == 'cancelled' %}
                                    <span class="badge bg-danger">Annule</span>
                                {% else %}
                                    <span class="badge bg-info">{{ course.status }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if course.createdBy.id == user.id %}
                                    <span class="badge bg-primary">Elu</span>
                                {% else %}
                                    <span class="badge bg-success">Chevalier</span>
                                {% endif %}
                            </td>
                            <td>{{ course.createdAt|date('d/m/Y') }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-muted text-center">Aucune course</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if user.role == 'chevalier' %}
        <!-- Info verification Chevalier -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-shield-check"></i> Verification Chevalier
            </div>
            <div class="card-body">
                <p><strong>Numero CNI:</strong> {{ user.idCardNumber ?? 'Non fourni' }}</p>
                {% if user.idCardPhotoPath %}
                    <p><strong>Photo CNI:</strong></p>
                    <img src="/uploads/{{ user.idCardPhotoPath }}" alt="CNI" class="img-thumbnail mb-2" style="max-width: 300px;">
                {% endif %}
                {% if user.selfieWithIdPath %}
                    <p><strong>Selfie avec CNI:</strong></p>
                    <img src="/uploads/{{ user.selfieWithIdPath }}" alt="Selfie" class="img-thumbnail" style="max-width: 300px;">
                {% endif %}
                {% if user.verifiedAt %}
                    <hr>
                    <p class="text-success"><i class="bi bi-check-circle"></i> Verifie le {{ user.verifiedAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
