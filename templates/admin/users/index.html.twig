{% extends 'admin/layout.html.twig' %}

{% block title %}Utilisateurs - Coursia Admin{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Liste des utilisateurs ({{ users|length }})</span>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: auto;" id="roleFilter">
                <option value="">Tous les roles</option>
                <option value="elu" {{ app.request.get('role') == 'elu' ? 'selected' : '' }}>Elus</option>
                <option value="chevalier" {{ app.request.get('role') == 'chevalier' ? 'selected' : '' }}>Chevaliers</option>
                <option value="admin" {{ app.request.get('role') == 'admin' ? 'selected' : '' }}>Admins</option>
            </select>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Telephone</th>
                    <th>Role</th>
                    <th>Statut</th>
                    <th>Inscrit le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td>#{{ user.id }}</td>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="bg-{{ user.role == 'admin' ? 'danger' : (user.role == 'chevalier' ? 'success' : 'primary') }} text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                {{ user.firstName|slice(0,1)|upper }}
                            </div>
                            {{ user.firstName }} {{ user.lastName }}
                        </div>
                    </td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.phone ?? '-' }}</td>
                    <td>
                        {% if user.role == 'admin' %}
                            <span class="badge bg-danger">Admin</span>
                        {% elseif user.role == 'chevalier' %}
                            <span class="badge bg-success">Chevalier</span>
                            {% if user.isVerified %}
                                <i class="bi bi-check-circle-fill text-success" title="Verifie"></i>
                            {% else %}
                                <i class="bi bi-x-circle-fill text-warning" title="Non verifie"></i>
                            {% endif %}
                        {% else %}
                            <span class="badge bg-primary">Elu</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.isActive %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactif</span>
                        {% endif %}
                    </td>
                    <td>{{ user.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <div class="btn-group">
                            <a href="{{ path('admin_users_show', {id: user.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            {% if user.isActive %}
                                <form method="POST" action="{{ path('admin_users_toggle', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('Désactiver cet utilisateur ?')">
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Désactiver">
                                        <i class="bi bi-pause-circle"></i>
                                    </button>
                                </form>
                            {% else %}
                                <form method="POST" action="{{ path('admin_users_toggle', {id: user.id}) }}" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Activer">
                                        <i class="bi bi-play-circle"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center text-muted">Aucun utilisateur</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>

<script>
document.getElementById('roleFilter').addEventListener('change', function() {
    const role = this.value;
    window.location.href = '{{ path('admin_users') }}' + (role ? '?role=' + role : '');
});
</script>
{% endblock %}
