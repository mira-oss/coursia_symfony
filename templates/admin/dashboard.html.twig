{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard - Coursia Admin{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block extra_css %}
<style>
    /* Welcome Banner */
    .welcome-banner {
        background: url('/images/Orange Room.jpeg') center center / cover no-repeat;
        border-radius: 20px;
        padding: 36px 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
        min-height: 200px;
    }

    .welcome-banner::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.35) 100%);
        border-radius: 20px;
    }

    .welcome-banner .welcome-text {
        position: relative;
        z-index: 1;
    }

    .welcome-banner .welcome-text .day {
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,0.5);
        margin-bottom: 6px;
        text-transform: capitalize;
    }

    .welcome-banner .welcome-text h2 {
        font-size: 32px;
        font-weight: 800;
        color: white;
        margin: 0 0 6px 0;
        letter-spacing: -0.5px;
    }

    .welcome-banner .welcome-text p {
        font-size: 15px;
        color: rgba(255,255,255,0.6);
        margin: 0;
    }

    .welcome-badges {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .welcome-badge {
        font-size: 12px;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 50px;
    }

    .welcome-badge.orange {
        background: rgba(249,115,22,0.2);
        color: #FB923C;
        border: 1px solid rgba(249,115,22,0.3);
    }

    .welcome-badge.green {
        background: rgba(22,163,74,0.2);
        color: #4ADE80;
        border: 1px solid rgba(22,163,74,0.3);
    }

    .welcome-badge.dark {
        background: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.75);
        border: 1px solid rgba(255,255,255,0.15);
    }

    @media (max-width: 768px) {
        .welcome-banner { padding: 24px; min-height: auto; }
        .welcome-banner .welcome-text h2 { font-size: 22px; }
    }

    /* Donut Chart */
    .donut-chart {
        position: relative;
        width: 180px;
        height: 180px;
    }

    .donut-chart svg {
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
    }

    .donut-chart circle {
        fill: none;
        stroke-width: 25;
    }

    .donut-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }

    .donut-center small {
        color: #9CA3AF;
        font-size: 12px;
    }

    .donut-center h2 {
        font-size: 32px;
        font-weight: 700;
        color: var(--coursia-dark);
        margin: 0;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .legend-text {
        flex: 1;
        font-size: 13px;
        color: #6B7280;
    }

    .legend-value {
        font-size: 13px;
        font-weight: 600;
        color: var(--coursia-dark);
    }

    .amount-cell {
        color: var(--coursia-orange);
        font-weight: 600;
    }

    /* Dark mode fixes for dashboard */
    [data-theme="dark"] .donut-center h2 {
        color: #F9FAFB !important;
    }

    [data-theme="dark"] .donut-center small {
        color: #9CA3AF !important;
    }

    [data-theme="dark"] .legend-text {
        color: #E5E7EB !important;
    }

    [data-theme="dark"] .legend-value {
        color: #F9FAFB !important;
    }

    [data-theme="dark"] .table td,
    [data-theme="dark"] .table th {
        color: #E5E7EB !important;
    }

    [data-theme="dark"] .table td strong {
        color: #F9FAFB !important;
    }
</style>
{% endblock %}

{% block content %}

<!-- Welcome Banner -->
<div class="welcome-banner mb-4">
    <div class="welcome-text">
        <div class="day"><i class="bi bi-calendar3 me-1"></i>{{ "now"|date("l d/m/Y") }}</div>
        <h2>Bonjour, {{ admin is defined and admin ? admin.firstName : 'Admin' }} 👋</h2>
        <p>Prêt à gérer vos livraisons aujourd'hui ?</p>
        <div class="welcome-badges mt-3">
            <span class="welcome-badge orange"><i class="bi bi-truck me-1"></i>{{ stats.totalCourses }} courses</span>
            <span class="welcome-badge green"><i class="bi bi-shield-check me-1"></i>{{ stats.totalChevaliers }} chevaliers</span>
            <span class="welcome-badge dark"><i class="bi bi-people me-1"></i>{{ stats.totalUsers }} utilisateurs</span>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4 g-4">
    <div class="col-md-3">
        <a href="{{ path('admin_courses') }}" class="stat-card-link">
        <div class="stat-card h-100">
            <div class="stat-icon orange">
                <i class="bi bi-truck"></i>
            </div>
            <div class="stat-info">
                <p>Courses
                    {% if currentPeriod == '7' %}(7 jours)
                    {% elseif currentPeriod == '30' %}(30 jours)
                    {% elseif currentPeriod == '90' %}(3 mois)
                    {% elseif currentPeriod == '365' %}(1 an)
                    {% else %}(total)
                    {% endif %}
                </p>
                <h3>{{ stats.periodCourses }} courses</h3>
                <div class="stat-trend">
                    <i class="bi bi-box-seam"></i> {{ stats.totalCourses }} au total
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_chevaliers_pending') }}" class="stat-card-link">
        <div class="stat-card h-100">
            <div class="stat-icon green">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="stat-info">
                <p>Chevaliers actifs</p>
                <h3>{{ stats.totalChevaliers }} livreurs</h3>
                <div class="stat-trend">
                    <i class="bi bi-clock-history"></i> {{ stats.pendingChevaliers }} en attente
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_users') }}" class="stat-card-link">
        <div class="stat-card h-100">
            <div class="stat-icon blue">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-info">
                <p>Utilisateurs total</p>
                <h3>{{ stats.totalUsers }}</h3>
                <div class="stat-trend">
                    <i class="bi bi-person-check"></i> {{ stats.totalUsers - stats.totalChevaliers }} élus
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_courses') }}" class="stat-card-link">
        <div class="stat-card h-100">
            <div class="stat-icon" style="background: rgba(16,185,129,0.1); color: #10B981;">
                <i class="bi bi-bar-chart-line"></i>
            </div>
            <div class="stat-info">
                <p>Statut des courses</p>
                <h3>{{ stats.coursesFinished }} terminées</h3>
                <div class="stat-trend" style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <span style="color: #F97316; font-size: 12px;">
                        <i class="bi bi-arrow-repeat"></i> {{ stats.coursesInProgress }} en cours
                    </span>
                    <span style="color: #EF4444; font-size: 12px;">
                        <i class="bi bi-x-circle"></i> {{ stats.coursesCancelled }} annulées
                    </span>
                </div>
            </div>
        </div>
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Graphe courses par statut -->
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-body">
                <div class="section-header">
                    <h5 class="section-title">Courses par statut</h5>
                    <a href="{{ path('admin_courses') }}" class="section-link">Voir tout ›</a>
                </div>
                <canvas id="coursesChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <!-- Graphe répartition utilisateurs -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-body">
                <div class="section-header">
                    <h5 class="section-title">Répartition utilisateurs</h5>
                </div>
                <div style="position:relative; max-width:220px; margin: 20px auto 0;">
                    <canvas id="usersChart"></canvas>
                </div>
                <div class="mt-4">
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#F97316;"></div>
                        <span class="legend-text">Chevaliers</span>
                        <span class="legend-value">{{ stats.totalChevaliers }}</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#16A34A;"></div>
                        <span class="legend-text">Élus</span>
                        <span class="legend-value">{{ stats.totalUsers - stats.totalChevaliers }}</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#FBBF24;"></div>
                        <span class="legend-text">Demandes en attente</span>
                        <span class="legend-value">{{ stats.pendingChevaliers }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Pending Chevaliers Section -->
{% if pendingRequests|length > 0 %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="section-header mb-3">
                    <h5 class="section-title">
                        <i class="bi bi-shield-check me-2 text-warning"></i>
                        Demandes Chevalier en attente
                        <span class="badge badge-pending ms-2">{{ stats.pendingChevaliers }}</span>
                    </h5>
                    <a href="{{ path('admin_chevaliers_pending') }}" class="section-link">Voir tout ></a>
                </div>

                <div class="row g-3">
                    {% for request in pendingRequests %}
                    <div class="col-md-4">
                        <div class="d-flex align-items-center p-3 rounded" style="background: var(--coursia-gray-light);">
                            <div style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--coursia-orange) 0%, #FB923C 100%); color: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 600; margin-right: 15px;">
                                {{ request.firstName|slice(0,1)|upper }}{{ request.lastName|slice(0,1)|upper }}
                            </div>
                            <div class="flex-grow-1">
                                <strong style="color: var(--coursia-dark);">{{ request.firstName }} {{ request.lastName }}</strong>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-{% if request.vehicleType == 'moto' %}bicycle{% else %}car-front{% endif %} me-1"></i>
                                    {{ request.vehicleType|capitalize }} - {{ request.createdAt|date('d/m/Y') }}
                                </small>
                            </div>
                            <a href="{{ path('admin_chevaliers_review', {id: request.id}) }}" class="btn btn-coursia btn-sm">
                                Voir
                            </a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block extra_js %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#9CA3AF' : '#6B7280';

// Graphe courses par statut
new Chart(document.getElementById('coursesChart'), {
    type: 'bar',
    data: {
        labels: ['Créées', 'Acceptées', 'En cours', 'Livrées', 'Terminées', 'Annulées'],
        datasets: [{
            label: 'Courses',
            data: [
                {{ stats.coursesCreated }},
                {{ stats.coursesAccepted }},
                {{ stats.coursesStarted }},
                {{ stats.coursesDelivered }},
                {{ stats.coursesFinished }},
                {{ stats.coursesCancelled }}
            ],
            backgroundColor: [
                'rgba(156,163,175,0.8)',
                'rgba(96,165,250,0.8)',
                'rgba(249,115,22,0.8)',
                'rgba(251,191,36,0.8)',
                'rgba(22,163,74,0.8)',
                'rgba(239,68,68,0.8)'
            ],
            borderRadius: 8,
            borderSkipped: false,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: gridColor }, ticks: { color: textColor } },
            y: { grid: { color: gridColor }, ticks: { color: textColor, stepSize: 1, precision: 0 }, beginAtZero: true }
        }
    }
});

// Graphe répartition utilisateurs
new Chart(document.getElementById('usersChart'), {
    type: 'doughnut',
    data: {
        labels: ['Chevaliers', 'Élus', 'En attente'],
        datasets: [{
            data: [
                {{ stats.totalChevaliers }},
                {{ stats.totalUsers - stats.totalChevaliers }},
                {{ stats.pendingChevaliers }}
            ],
            backgroundColor: ['#F97316', '#16A34A', '#FBBF24'],
            borderWidth: 0,
            hoverOffset: 6
        }]
    },
    options: {
        cutout: '70%',
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw}` } }
        }
    }
});
</script>
{% endblock %}
