<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Réinitialisation du mot de passe - Coursia</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --coursia-orange: #F97316;
            --coursia-orange-hover: #EA580C;
            --coursia-dark: #020617;
        }
        * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
        body {
            background: #F3F4F6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }
        .card-wrap {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.10);
            overflow: hidden;
            display: flex;
            width: 100%;
            max-width: 900px;
            min-height: 480px;
        }
        .panel-left {
            flex: 0 0 42%;
            background: linear-gradient(145deg, rgba(249,115,22,0.92), rgba(16,163,74,0.75)),
                        url('/uploads/Orange\ Room.jpeg') center/cover no-repeat;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: flex-start;
            padding: 40px 36px;
            position: relative;
            overflow: hidden;
        }
        .panel-left::before,
        .panel-left::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            opacity: 0.15;
        }
        .panel-left::before { width: 260px; height: 260px; background: white; top: -80px; right: -80px; }
        .panel-left::after  { width: 180px; height: 180px; background: white; bottom: 30px; right: -50px; }
        .brand { position: absolute; top: 36px; left: 36px; display: flex; align-items: center; gap: 10px; }
        .brand i { font-size: 26px; color: white; }
        .brand span { font-size: 22px; font-weight: 700; color: white; }
        .panel-left-text { position: relative; z-index: 1; }
        .panel-left-text h2 { color: white; font-size: 26px; font-weight: 700; margin-bottom: 10px; }
        .panel-left-text p  { color: rgba(255,255,255,0.85); font-size: 14px; line-height: 1.6; }
        .panel-right {
            flex: 1;
            padding: 52px 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .form-title { font-size: 22px; font-weight: 700; color: var(--coursia-dark); margin-bottom: 6px; }
        .form-sub { color: #6B7280; font-size: 14px; margin-bottom: 32px; }
        .field-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: #9CA3AF; margin-bottom: 6px; }
        .input-wrap {
            display: flex;
            align-items: center;
            border-bottom: 2px solid #E5E7EB;
            margin-bottom: 24px;
            transition: border-color 0.25s;
        }
        .input-wrap:focus-within { border-color: var(--coursia-orange); }
        .input-wrap i { color: #9CA3AF; margin-right: 10px; font-size: 17px; }
        .input-wrap input {
            flex: 1;
            border: none;
            outline: none;
            padding: 10px 0;
            font-size: 14px;
            background: transparent;
            color: var(--coursia-dark);
        }
        .input-wrap .toggle-pwd { background: none; border: none; color: #9CA3AF; cursor: pointer; padding: 0; font-size: 16px; }
        .btn-submit {
            width: 100%;
            background: var(--coursia-dark);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 14px;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.25s;
            margin-top: 8px;
        }
        .btn-submit:hover { background: #1F2937; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
        .alert-box {
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .alert-error { background: #FEE2E2; color: #991B1B; }
        .state-icon { font-size: 52px; text-align: center; margin-bottom: 16px; }
        @media (max-width: 640px) {
            .panel-left { display: none; }
            .panel-right { padding: 40px 28px; }
        }
    </style>
</head>
<body>
<div class="card-wrap">
    <div class="panel-left">
        <div class="brand">
            <i class="bi bi-box-seam"></i>
            <span>Coursia</span>
        </div>
        <div class="panel-left-text">
            <h2>Sécurisez<br>votre compte</h2>
            <p>Choisissez un mot de passe fort d'au moins 6 caractères.</p>
        </div>
    </div>

    <div class="panel-right">
        {% if invalid %}
            <div class="state-icon">⛔</div>
            <h1 class="form-title" style="text-align:center">Lien invalide</h1>
            <p class="form-sub" style="text-align:center">Ce lien de réinitialisation est expiré ou déjà utilisé.<br>Veuillez refaire la procédure depuis l'application.</p>
        {% elseif success %}
            <div class="state-icon">✅</div>
            <h1 class="form-title" style="text-align:center">Mot de passe modifié !</h1>
            <p class="form-sub" style="text-align:center">Votre mot de passe a été réinitialisé avec succès.<br>Vous pouvez maintenant vous connecter dans l'application Coursia.</p>
        {% else %}
            <h1 class="form-title">Nouveau mot de passe</h1>
            <p class="form-sub">Saisissez et confirmez votre nouveau mot de passe.</p>

            {% if error %}
                <div class="alert-box alert-error">
                    <i class="bi bi-exclamation-circle"></i> {{ error }}
                </div>
            {% endif %}

            <form method="POST" action="{{ path('web_reset_password', {token: token}) }}">
                <label class="field-label">NOUVEAU MOT DE PASSE</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="newPassword" id="newPwd" placeholder="Minimum 6 caractères" required minlength="6" autocomplete="new-password">
                    <button type="button" class="toggle-pwd" onclick="togglePwd('newPwd', this)"><i class="bi bi-eye-slash"></i></button>
                </div>

                <label class="field-label">CONFIRMER LE MOT DE PASSE</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input type="password" name="confirmPassword" id="confirmPwd" placeholder="Répétez le mot de passe" required minlength="6" autocomplete="new-password">
                    <button type="button" class="toggle-pwd" onclick="togglePwd('confirmPwd', this)"><i class="bi bi-eye-slash"></i></button>
                </div>

                <button type="submit" class="btn-submit">Enregistrer le nouveau mot de passe</button>
            </form>
        {% endif %}
    </div>
</div>

<script>
function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye-slash';
    }
}
</script>
</body>
</html>
